<!DOCTYPE html>
<html lang="zh">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Just playground</title>
</head>

<body>
    <div id="app"></div>
    <script src="./dist/lib.js"></script>
    <script>
        const MyApp = createComponent({
            props: {
                text: { transform: String }
            }
        }, ({ text }) =>
            tree("div")
                .append(
                    tree("span")
                        .append($(text))
                        .on("click", () => text.set(text.get() + "!"))
                )
        );
        const app = MyApp({ text: "Hello Nine9 !" }).mount("#app");
        console.log(app);
    </script>
</body>

</html>